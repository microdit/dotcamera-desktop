{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Electron: Start Development",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "windows": {
        "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron.cmd"
      },
      "args": ["."],
      "outputCapture": "std"
    },
    {
      "name": "Electron: Attach to Renderer",
      "type": "node",
      "request": "attach",
      "port": 9222,
      "webContentsId": "*"
    }
  ]
}